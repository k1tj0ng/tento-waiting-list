# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon public key (Project Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret shared between Vercel Cron and the /api/wipe fallback endpoint.
# Generate with:  openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# Service role key — server-only, NEVER prefix with NEXT_PUBLIC_
# Only required if using the /api/wipe fallback endpoint.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
